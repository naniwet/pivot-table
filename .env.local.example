# 复制为 .env.local（已 gitignore），按需填写
# Smartbi JWT，从浏览器 cookie / 页面 localStorage 取
VITE_SMARTBI_TOKEN=st_xxx

# 数据模型 ID
VITE_SMARTBI_MODEL_ID=I8a8aa3ed018ff259f259763901900f943a901c9a

# 可选：开发代理目标（默认 http://10.10.202.100:28082）— 只在 baseUrl 是相对路径时生效
# VITE_PROXY_TARGET=http://10.10.202.100:28082

# 可选:Smartbi baseUrl(默认 /smartbi —— 走 vite proxy 绕 CORS)
# 后端如果开了 CORS,改成完整 URL 直连也行,如 http://host:port/smartbi
# 注:填到 /smartbi 即止,demo 自动拼 /smartbix(SmartbiClient 真实接 .../smartbi/smartbix/api/...)
# VITE_SMARTBI_BASE=/smartbi
