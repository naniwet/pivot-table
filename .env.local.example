# 复制为 .env.local(已 gitignore),按需填写
# Smartbi JWT,从浏览器 cookie / 页面 localStorage 取
VITE_SMARTBI_TOKEN=st_xxx_paste_your_token_here

# 数据模型 ID
VITE_SMARTBI_MODEL_ID=your_model_id_here

# 可选:开发代理目标(只在 baseUrl 是相对路径时 vite proxy 用)
# VITE_PROXY_TARGET=http://your-backend-host:port

# 可选:Smartbi baseUrl(默认 /smartbi —— 走 vite proxy 绕 CORS)
# 后端如果开了 CORS,改成完整 URL 直连也行,如 http://your-host:port/smartbi
# 注:填到 /smartbi 即止,demo 自动拼 /smartbix(SmartbiClient 真实接 .../smartbi/smartbix/api/...)
# VITE_SMARTBI_BASE=/smartbi
