{
  "name": "@company/pivot-table",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Web 数据透视表组件 — 复用 Smartbi 后端 query 接口的可嵌入前端组件",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "concurrently -n vite,proxy -c blue,green \"npm run dev:vite\" \"npm run dev:proxy\"",
    "dev:vite": "vite",
    "dev:proxy": "node proxy/server.js",
    "build:demo": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run src/core src/types",
    "test:integration": "vitest run src/hooks src/components src/api",
    "test:contract": "vitest run src/core/queryBuilder src/core/drillThrough src/core/viewConfig src/core/dropRules",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "probe:baseline": "npx tsx scripts/probe-baseline.ts",
    "probe:final": "npx tsx scripts/probe-final.ts",
    "probe:edge": "npx tsx scripts/probe-edge-cases.ts",
    "probe:calc": "npx tsx scripts/probe-calc-final.ts",
    "probe:adhoc": "npx tsx scripts/probe-adhoc-cross.ts",
    "probe:smoke": "npm run probe:baseline && npm run probe:final && npm run probe:calc && npm run probe:adhoc"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^1.6.0",
    "concurrently": "^8.2.2",
    "echarts": "^5.6.0",
    "express": "^4.21.0",
    "http-proxy-middleware": "^3.0.3",
    "jsdom": "^24.1.3",
    "playwright": "^1.60.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "echarts": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "peerDependenciesMeta": {
    "echarts": {
      "optional": true
    }
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  }
}
