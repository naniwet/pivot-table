    },
    "SubTotalCalcBasis": {
      "type": "string",
      "enum": ["ParentLevel", "CurrentLevel"],
      "description": "分组占比中小计合计基准"
    },
    "RankSortDirection": {
      "type": "string",
      "enum": ["ASC", "DESC"]
    },
    "SortDirection": {
      "type": "string",
      "enum": ["ASC", "DESC", "BASC", "BDESC"]
    },
    "ValueType": {
      "type": "string",
      "enum": ["STRING", "INTEGER", "LONG", "BIGINT", "FLOAT", "DOUBLE", "BIGDECIMAL", "DATE", "TIME", "DATETIME", "BOOLEAN", "ASCII_CODE", "NUMERIC", "TIMESTAMP"]
    },
    "LevelType": {
      "type": "object",
      "properties": {
        "type": { "type": "string" }
      },
      "required": ["type"]
    },
    "Member": {
      "type": "object",
      "description": "维度成员",
      "properties": {
        "name": { "type": "string" },
        "uniqueName": {
          "type": "array",
          "description": "from top to bottom, e.g. [\"Measures\", \"销售额\"]",
          "items": { "type": "string" }
        },
        "level": { "type": "string" },
        "dimension": { "type": "string" },
        "fieldName": { "type": "string" },
        "value": {},
        "formattedValue": { "type": "string" },
        "valueType": { "$ref": "#/definitions/ValueType" },
        "useTransformRule": { "type": "boolean", "default": false }
      },
      "required": ["name", "uniqueName", "level", "dimension", "fieldName"]
    },
    "Cell": {
      "type": "object",
      "description": "压缩矩阵单元格",
      "properties": {
        "row": { "type": "integer" },
        "column": { "type": "integer" },
        "value": {},
        "formattedValue": { "type": "string" },
        "valueType": { "$ref": "#/definitions/ValueType" },
        "useTransformRule": { "type": "boolean", "default": false }
      },
      "required": ["row", "column", "value", "formattedValue"]
    },
    "Filter": {
      "type": "object",
      "properties": {
        "_enum": {
          "type": "string",
          "enum": ["ByValue", "ByLevel", "ByMeasure", "And", "Or", "Not", "NoneFilter"]
        }
      },
      "required": ["_enum"],
      "oneOf": [
        {
          "type": "object",
          "description": "按维度值进行筛选",
          "properties": {
            "_enum": { "const": "ByValue" },
            "operator": { "$ref": "#/definitions/BinaryOperator" },
            "value": { "$ref": "#/definitions/FilterLiteral" }
          },
          "required": ["_enum", "operator", "value"]
        },
        {
          "type": "object",
          "description": "按层级筛选",
          "properties": {
            "_enum": { "const": "ByLevel" },
            "level": { "type": "string" },
            "operator": { "$ref": "#/definitions/BinaryOperator" },
            "value": { "$ref": "#/definitions/FilterLiteral" }
          },
          "required": ["_enum", "level", "operator", "value"]
        },
        {
          "type": "object",
          "description": "按度量值进行筛选, 可以选择全局/组内上下文",
          "properties": {
            "_enum": { "const": "ByMeasure" },
            "measure": { "type": "string" },
            "measureContext": { "$ref": "#/definitions/MeasureContext" },
            "operator": { "$ref": "#/definitions/BinaryOperator" },
            "value": { "$ref": "#/definitions/FilterLiteral" }
          },
          "required": ["_enum", "measure", "measureContext", "operator", "value"]
        },
        {
          "type": "object",
          "description": "逻辑与",
          "properties": {
            "_enum": { "const": "And" },
            "left": { "$ref": "#/definitions/Filter" },
            "right": { "$ref": "#/definitions/Filter" }
          },
          "required": ["_enum", "left", "right"]
        },
        {
          "type": "object",
          "description": "逻辑或",
          "properties": {
            "_enum": { "const": "Or" },
            "left": { "$ref": "#/definitions/Filter" },
            "right": { "$ref": "#/definitions/Filter" }
          },
          "required": ["_enum", "left", "right"]
        },
        {
          "type": "object",
          "description": "逻辑非",
          "properties": {
            "_enum": { "const": "Not" },
            "expr": { "$ref": "#/definitions/Filter" }
          },
          "required": ["_enum", "expr"]
        },
        {
          "type": "object",
          "description": "将无关维度filter替换为1=1或0=1",
          "properties": {
            "_enum": { "const": "NoneFilter" },
            "value": { "$ref": "#/definitions/FilterLiteral" },
            "operator": { "$ref": "#/definitions/BinaryOperator", "default": "Equals" },
            "value2": { "$ref": "#/definitions/FilterLiteral", "default": 1 }
          },
          "required": ["_enum", "value"]
        }
      ]
    },
    "FilterLiteral": {
      "oneOf": [
        { "type": "boolean" },
        { "type": "integer" },
        { "type": "number" },
        { "type": "string" },
        { "type": "array", "items": { "type": "integer" } },
        { "type": "array", "items": { "type": "number" } },
        { "type": "array", "items": { "type": "boolean" } },
        { "type": "array", "items": { "type": "string" } },
        { "type": "array", "items": { "type": "string" }, "description": "List[String]" },
        { "type": "null", "description": "NullLiteral" }
      ]
    },
    "BinaryOperator": {
      "type": "string",
      "enum": [
        "Equals", "NotEquals", "In", "NotIn", "Like", "StartsWith", "EndsWith",
        "Contains", "GreaterThan", "GreaterThanOrEqual", "LessThan", "LessThanOrEqual",
        "NotLike", "NotLikeStart", "NotLikeEnd"
      ]
    },
    "MeasureContext": {
      "type": "string",
      "enum": ["InGlobal", "InGroup"],
      "description": "InGlobal: 全局上下文, InGroup: 组内上下文"
    }
  }
}
