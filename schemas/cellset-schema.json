        { "properties": { "_enum": { "const": "PeriodEndCumulativeValue" }, "dateDimension": { "type": "string" }, "dateLevel": { "type": "string" }, "extensions": { "type": ["object", "null"], "default": null } }, "required": ["_enum", "dateDimension", "dateLevel"] },
        { "properties": { "_enum": { "const": "PeriodEndSamePeriodValue" }, "dateDimension": { "type": "string" }, "periodEndLevel": { "type": "string" }, "samePeriodLevel": { "type": "string" }, "isSearchForward": { "type": "boolean" }, "offset": { "type": "integer" }, "extensions": { "type": ["object", "null"], "default": null } }, "required": ["_enum", "dateDimension", "periodEndLevel", "samePeriodLevel", "isSearchForward", "offset"] },
