        { "properties": { "_enum": { "const": "AggregateValue" }, "contextDimensions": { "type": "array", "items": { "type": "string" } }, "filter": { "oneOf": [{ "$ref": "#/definitions/Filter" }, { "type": "null" }] }, "extensions": { "type": ["object", "null"], "default": null } }, "required": ["_enum", "contextDimensions", "filter"] },
